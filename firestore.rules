rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Bids: tighter rules. A bid can only be created if:
    //   1. caller is authenticated
    //   2. bid.buyerId matches caller's auth uid (no impersonation)
    //   3. bid.buyerId is NOT the same as the listing's sellerId (no self-bids)
    match /bids/{bidId} {
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.buyerId != get(/databases/$(database)/documents/listings/$(request.resource.data.listingId)).data.sellerId;
    }

    // Everything else: authenticated read/write (matches current behavior).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
